{
  "source": "IPIP Big-Five Factor Markers (50-item lexical scale)",
  "sourceUrl": "https://ipip.ori.org/newBigFive5broadKey.htm",
  "license": "Public Domain (IPIP Terms of Use)",
  "attribution": "International Personality Item Pool (IPIP) — Goldberg, L. R. (1992). The development of markers for the Big-Five factor structure. Psychological Assessment, 4, 26–42.",
  "germanTranslator": "Fritz Ostendorf (via ipip.ori.org/German50-itemBigFiveFactorMarkers.htm). Three purely orthographic fixes vs. the source: 'beleidge'→'beleidige' (bf-a-03), 'grübel'→'grüble' (bf-n-03), 'wechsel'→'wechsle' (bf-n-07). No semantic changes.",
  "items": [
    { "id": "bf-o-01", "layer": "bigfive", "dimension": "openness", "scale": "likert5", "text": { "en": "Have a rich vocabulary.", "de": "Ich besitze einen großen Wortschatz." } },
    { "id": "bf-o-02", "layer": "bigfive", "dimension": "openness", "scale": "likert5", "reverse": true, "text": { "en": "Have difficulty understanding abstract ideas.", "de": "Ich habe Schwierigkeiten, abstrakte Ideen zu verstehen." } },
    { "id": "bf-o-03", "layer": "bigfive", "dimension": "openness", "scale": "likert5", "text": { "en": "Have a vivid imagination.", "de": "Ich habe eine lebhafte Vorstellungskraft." } },
    { "id": "bf-o-04", "layer": "bigfive", "dimension": "openness", "scale": "likert5", "reverse": true, "text": { "en": "Am not interested in abstract ideas.", "de": "Ich bin an abstrakten Ideen nicht interessiert." } },
    { "id": "bf-o-05", "layer": "bigfive", "dimension": "openness", "scale": "likert5", "text": { "en": "Have excellent ideas.", "de": "Ich habe ausgezeichnete Ideen." } },
    { "id": "bf-o-06", "layer": "bigfive", "dimension": "openness", "scale": "likert5", "reverse": true, "text": { "en": "Do not have a good imagination.", "de": "Ich habe kein gutes Vorstellungsvermögen." } },
    { "id": "bf-o-07", "layer": "bigfive", "dimension": "openness", "scale": "likert5", "text": { "en": "Am quick to understand things.", "de": "Ich verstehe Dinge schnell." } },
    { "id": "bf-o-08", "layer": "bigfive", "dimension": "openness", "scale": "likert5", "text": { "en": "Use difficult words.", "de": "Ich gebrauche schwierige Wörter." } },
    { "id": "bf-o-09", "layer": "bigfive", "dimension": "openness", "scale": "likert5", "text": { "en": "Spend time reflecting on things.", "de": "Ich verbringe Zeit damit, über Dinge nachzudenken." } },
    { "id": "bf-o-10", "layer": "bigfive", "dimension": "openness", "scale": "likert5", "text": { "en": "Am full of ideas.", "de": "Ich bin voller Ideen." } },

    { "id": "bf-c-01", "layer": "bigfive", "dimension": "conscientiousness", "scale": "likert5", "text": { "en": "Am always prepared.", "de": "Ich bin immer vorbereitet." } },
    { "id": "bf-c-02", "layer": "bigfive", "dimension": "conscientiousness", "scale": "likert5", "reverse": true, "text": { "en": "Leave my belongings around.", "de": "Ich lasse meine Sachen herumliegen." } },
    { "id": "bf-c-03", "layer": "bigfive", "dimension": "conscientiousness", "scale": "likert5", "text": { "en": "Pay attention to details.", "de": "Ich achte auf Details." } },
    { "id": "bf-c-04", "layer": "bigfive", "dimension": "conscientiousness", "scale": "likert5", "reverse": true, "text": { "en": "Make a mess of things.", "de": "Ich verursache großes Durcheinander." } },
    { "id": "bf-c-05", "layer": "bigfive", "dimension": "conscientiousness", "scale": "likert5", "text": { "en": "Get chores done right away.", "de": "Ich erledige Hausarbeiten unmittelbar." } },
    { "id": "bf-c-06", "layer": "bigfive", "dimension": "conscientiousness", "scale": "likert5", "reverse": true, "text": { "en": "Often forget to put things back in their proper place.", "de": "Ich vergesse oft, Dinge an ihren Platz zurückzulegen." } },
    { "id": "bf-c-07", "layer": "bigfive", "dimension": "conscientiousness", "scale": "likert5", "text": { "en": "Like order.", "de": "Ich mag Ordnung." } },
    { "id": "bf-c-08", "layer": "bigfive", "dimension": "conscientiousness", "scale": "likert5", "reverse": true, "text": { "en": "Shirk my duties.", "de": "Ich drücke mich vor meinen Pflichten." } },
    { "id": "bf-c-09", "layer": "bigfive", "dimension": "conscientiousness", "scale": "likert5", "text": { "en": "Follow a schedule.", "de": "Ich folge einem Plan." } },
    { "id": "bf-c-10", "layer": "bigfive", "dimension": "conscientiousness", "scale": "likert5", "text": { "en": "Am exacting in my work.", "de": "Ich bin anspruchsvoll in meiner Arbeit." } },

    { "id": "bf-e-01", "layer": "bigfive", "dimension": "extraversion", "scale": "likert5", "text": { "en": "Am the life of the party.", "de": "Ich bringe eine Party in Schwung." } },
    { "id": "bf-e-02", "layer": "bigfive", "dimension": "extraversion", "scale": "likert5", "reverse": true, "text": { "en": "Don't talk a lot.", "de": "Ich spreche nicht viel." } },
    { "id": "bf-e-03", "layer": "bigfive", "dimension": "extraversion", "scale": "likert5", "text": { "en": "Feel comfortable around people.", "de": "Ich fühle mich wohl unter Menschen." } },
    { "id": "bf-e-04", "layer": "bigfive", "dimension": "extraversion", "scale": "likert5", "reverse": true, "text": { "en": "Keep in the background.", "de": "Ich halte mich im Hintergrund." } },
    { "id": "bf-e-05", "layer": "bigfive", "dimension": "extraversion", "scale": "likert5", "text": { "en": "Start conversations.", "de": "Ich beginne Gespräche." } },
    { "id": "bf-e-06", "layer": "bigfive", "dimension": "extraversion", "scale": "likert5", "reverse": true, "text": { "en": "Have little to say.", "de": "Ich habe wenig zu sagen." } },
    { "id": "bf-e-07", "layer": "bigfive", "dimension": "extraversion", "scale": "likert5", "text": { "en": "Talk to a lot of different people at parties.", "de": "Ich spreche mit vielen verschiedenen Leuten auf Parties." } },
    { "id": "bf-e-08", "layer": "bigfive", "dimension": "extraversion", "scale": "likert5", "reverse": true, "text": { "en": "Don't like to draw attention to myself.", "de": "Ich mag es nicht, Aufmerksamkeit auf mich zu ziehen." } },
    { "id": "bf-e-09", "layer": "bigfive", "dimension": "extraversion", "scale": "likert5", "text": { "en": "Don't mind being the center of attention.", "de": "Es macht mir nichts aus, im Zentrum der Aufmerksamkeit zu stehen." } },
    { "id": "bf-e-10", "layer": "bigfive", "dimension": "extraversion", "scale": "likert5", "reverse": true, "text": { "en": "Am quiet around strangers.", "de": "Ich bin still unter Fremden." } },

    { "id": "bf-a-01", "layer": "bigfive", "dimension": "agreeableness", "scale": "likert5", "reverse": true, "text": { "en": "Feel little concern for others.", "de": "Ich empfinde wenig für andere." } },
    { "id": "bf-a-02", "layer": "bigfive", "dimension": "agreeableness", "scale": "likert5", "text": { "en": "Am interested in people.", "de": "Ich bin interessiert an anderen Menschen." } },
    { "id": "bf-a-03", "layer": "bigfive", "dimension": "agreeableness", "scale": "likert5", "reverse": true, "text": { "en": "Insult people.", "de": "Ich beleidige andere." } },
    { "id": "bf-a-04", "layer": "bigfive", "dimension": "agreeableness", "scale": "likert5", "text": { "en": "Sympathize with others' feelings.", "de": "Ich fühle mit anderen Menschen mit." } },
    { "id": "bf-a-05", "layer": "bigfive", "dimension": "agreeableness", "scale": "likert5", "reverse": true, "text": { "en": "Am not interested in other people's problems.", "de": "Ich bin nicht interessiert an den Problemen anderer Leute." } },
    { "id": "bf-a-06", "layer": "bigfive", "dimension": "agreeableness", "scale": "likert5", "text": { "en": "Have a soft heart.", "de": "Ich habe ein weiches Herz." } },
    { "id": "bf-a-07", "layer": "bigfive", "dimension": "agreeableness", "scale": "likert5", "reverse": true, "text": { "en": "Am not really interested in others.", "de": "Ich bin nicht wirklich interessiert an anderen." } },
    { "id": "bf-a-08", "layer": "bigfive", "dimension": "agreeableness", "scale": "likert5", "text": { "en": "Take time out for others.", "de": "Ich nehme mir Zeit für andere." } },
    { "id": "bf-a-09", "layer": "bigfive", "dimension": "agreeableness", "scale": "likert5", "text": { "en": "Feel others' emotions.", "de": "Ich fühle die Gefühle anderer." } },
    { "id": "bf-a-10", "layer": "bigfive", "dimension": "agreeableness", "scale": "likert5", "text": { "en": "Make people feel at ease.", "de": "Ich kann andere beruhigen." } },

    { "id": "bf-n-01", "layer": "bigfive", "dimension": "neuroticism", "scale": "likert5", "text": { "en": "Get stressed out easily.", "de": "Ich gerate leicht in Stress." } },
    { "id": "bf-n-02", "layer": "bigfive", "dimension": "neuroticism", "scale": "likert5", "reverse": true, "text": { "en": "Am relaxed most of the time.", "de": "Ich bin die meiste Zeit entspannt." } },
    { "id": "bf-n-03", "layer": "bigfive", "dimension": "neuroticism", "scale": "likert5", "text": { "en": "Worry about things.", "de": "Ich grüble über Dinge." } },
    { "id": "bf-n-04", "layer": "bigfive", "dimension": "neuroticism", "scale": "likert5", "reverse": true, "text": { "en": "Seldom feel blue.", "de": "Ich fühle mich selten deprimiert." } },
    { "id": "bf-n-05", "layer": "bigfive", "dimension": "neuroticism", "scale": "likert5", "text": { "en": "Am easily disturbed.", "de": "Ich bin leicht beunruhigt." } },
    { "id": "bf-n-06", "layer": "bigfive", "dimension": "neuroticism", "scale": "likert5", "text": { "en": "Get upset easily.", "de": "Ich rege mich leicht auf." } },
    { "id": "bf-n-07", "layer": "bigfive", "dimension": "neuroticism", "scale": "likert5", "text": { "en": "Change my mood a lot.", "de": "Ich wechsle oft meine Stimmung." } },
    { "id": "bf-n-08", "layer": "bigfive", "dimension": "neuroticism", "scale": "likert5", "text": { "en": "Have frequent mood swings.", "de": "Ich habe häufig Stimmungsschwankungen." } },
    { "id": "bf-n-09", "layer": "bigfive", "dimension": "neuroticism", "scale": "likert5", "text": { "en": "Get irritated easily.", "de": "Ich bin leicht gereizt." } },
    { "id": "bf-n-10", "layer": "bigfive", "dimension": "neuroticism", "scale": "likert5", "text": { "en": "Often feel blue.", "de": "Ich fühle mich oft deprimiert." } }
  ]
}
